{#
  Component: product-grid
  Params:
    products        — array of product objects (required)
    sort_id         — id for the sort <select> / <label for> (default: 'product-sort')
    empty_message   — text shown when products is empty (default: 'No products found.')
  Context (inherited from parent):
    current_page_url
    current_orderby
#}

{% set sort_id       = sort_id       ?? 'product-sort' %}
{% set empty_message = empty_message ?? 'No products found.' %}

<section>
    <div class="bg-[rgb(244,244,244)] text-text section-spacing section-padding"
        style="
            --scheme-background: 244 244 244;
            --scheme-text: 28 28 26;
            --scheme-accent: 17 221 196;
            --scheme-border: 73 73 72;
            --section-padding-sm: 3rem;
            --section-padding-md: 4rem;
            --section-padding-lg: 5rem;
        ">
        <div class="wrapper">

            {# Sort bar #}
            <div class="flex justify-end mb-8">
                <form method="get" action="{{ current_page_url|e }}">
                    <label for="{{ sort_id }}" class="text-sm mr-2">Sort by:</label>
                    <select
                        id="{{ sort_id }}"
                        name="orderby"
                        onchange="this.form.submit()"
                        class="border border-[rgb(var(--scheme-border))] bg-transparent text-sm px-3 py-2 cursor-pointer">
                        <option value="featured"     {{ current_orderby == 'featured'     ? 'selected' : '' }}>Featured</option>
                        <option value="best_selling" {{ current_orderby == 'best_selling' ? 'selected' : '' }}>Best Selling</option>
                        <option value="az"           {{ current_orderby == 'az'           ? 'selected' : '' }}>A – Z</option>
                        <option value="za"           {{ current_orderby == 'za'           ? 'selected' : '' }}>Z – A</option>
                    </select>
                </form>
            </div>

            {# Product grid #}
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-10 pb-[50px]">
                {% for product in products %}
                <div class="flex flex-col gap-4">

                    <a href="{{ product.product_url|e }}" aria-label="View {{ product.card_title|e }}" class="w-full block">
                        <div class="relative w-full" style="padding-bottom: 102.77%;">
                            {% if product.is_new %}
                                <div class="absolute left-4 top-4 z-2">
                                    <div class="flex gap-2">
                                        <span class="rounded-full font-medium uppercase tracking-wide px-3 py-1.5 text-sm text-white bg-[rgb(var(--scheme-text))]">New</span>
                                    </div>
                                </div>
                            {% endif %}
                            {% if product.product_id %}
                                <div class="absolute right-3 top-3 z-2">
                                    {% include 'components/favorite-button.twig' with {
                                        product_id: product.product_id,
                                        add_class: 'w-9 h-9 flex items-center justify-center rounded-full bg-white/80 hover:bg-white text-gray-500 hover:text-red-500 transition-colors shadow-sm'
                                    } %}
                                </div>
                            {% endif %}
                            <img
                                src="{{ product.card_image_src|default('')|e }}"
                                alt="{{ product.card_image_alt_attribute|default('')|e }}"
                                width="1000" height="1034"
                                loading="lazy"
                                class="absolute inset-0 w-full h-full object-contain rounded-general"
                            >
                        </div>
                    </a>

                    <div class="flex flex-col gap-2">
                        <div class="richtext-prose">
                            <h4>{{ product.card_title|default('')|e }}</h4>
                        </div>
                        {% if product.price_html %}
                            <div class="text-body2">{{ product.price_html|raw }}</div>
                        {% endif %}
                        {% if product.card_description %}
                            <div class="richtext-prose text-eyebrow">
                                <p>{{ product.card_description|e }}</p>
                            </div>
                        {% endif %}
                    </div>

                    <div class="flex flex-wrap gap-3 mt-auto">
                        <a
                            href="{{ product.product_url|e }}"
                            class="button button--secondary"
                            aria-label="See details for {{ product.card_title|e }}">
                            See Details
                        </a>
                        <a
                            href="{{ product.add_to_cart_url|e }}"
                            class="button"
                            aria-label="Add {{ product.card_title|e }} to cart">
                            Add to Cart
                        </a>
                    </div>

                </div>
                {% else %}
                    <p class="col-span-3">{{ empty_message }}</p>
                {% endfor %}
            </div>

        </div>
    </div>
</section>
