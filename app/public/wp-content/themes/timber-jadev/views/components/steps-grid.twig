<section>
    <div
        class="{{ rct_darkbg ? rct_darkbg : 'bg-[rgb(244,244,244)]' }} section-padding text-text"
        style="
            --scheme-background: {{ rct_darkbg ? '28 28 26' : '244 244 244' }};
            --scheme-text: {{ rct_darkbg ? '244 244 244' : '28 28 26' }};
            --scheme-accent: 17 221 196;
            --section-padding-sm: 3rem;
            --section-padding-md: 4rem;
            --section-padding-lg: 5rem;
        ">
        <div class="wrapper">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-10">
                {% for step in steps %}
                    <div class="flex flex-col gap-3 text-[rgb(var(--scheme-text))]">
                        <span class="text-sm font-bold uppercase tracking-widest text-[rgb(var(--scheme-accent))]">
                            {{ step.label|default('')|e }}
                        </span>
                        <h3 class="text-heading-sm font-bold">
                            {{ step.title|default('')|e }}
                        </h3>
                        <div>
                            {{ step.description|default('')|raw }}
                        </div>
                    </div>
                {% endfor %}
            </div>

            <div class="flex flex-col items-center sm:items-center w-full gap-6">
                {{ step.additional_info|default('')|raw }}
            </div>
        </div>
    </div>
</section>
