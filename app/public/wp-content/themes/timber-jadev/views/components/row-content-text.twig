<section>
  <div 
    class="section-spacing section-padding {{ rct_darkbg ? rct_darkbg : 'bg-[rgb(244,244,244)]' }} {{ add_class|default('')|e }}" 
    style="
      --scheme-disabled-accent: 73 73 72;
      --scheme-disabled: 210 210 209;
      --scheme-error: 189 32 32;
      --scheme-approved: 94 199 98;
      --scheme-on-accent: 28 28 26;
      --scheme-accent: 17 221 196;
      --scheme-border: 164 164 163;
      --scheme-alternate-background: ;
      --scheme-background: {{ rct_darkbg ? "28 28 26" : "244 244 244" }}; 
      --scheme-text: {{ rct_darkbg ? "244 244 244" : "28 28 26" }}; 
      --section-padding-sm: 3rem;
      --section-padding-md: 4rem;
      --section-padding-lg: 5rem
    ">
      <div class="wrapper sm:max-w-full sm:mt-0 sm:mb-0 flex justify-center ">
        <div class="flex flex-col items-center w-full gap-6">
          <animate-scroll
            class="text-center text-body-lg text-text prose opacity-0 block animate-eased-slide-up"
            style="animation-delay: calc(0*100ms)">

            {% if rct_title %}
              <h2 class="text-[2.5rem] mt-[0.5em]">
                {{ rct_title|default('')|e }}
              </h2>
            {% endif %}
          </animate-scroll>
          {% if rct_button is not empty %}
              <div class="flex flex-wrap justify-center items-center gap-6">
                <animate-scroll 
                  style="animation-delay: calc(1*100ms)" 
                  class="opacity-0 block animate-eased-slide-up">
                    <a 
                      href="{{ rct_button.rct_button_url|default('#')|e }}" 
                      class="link" aria-label="{{ rct_button.rct_button_arialabel|default('')|e }}" 
                      data-marketing-cta="">
                        {{ rct_button.rct_button_text|default('#')|e }}
                    </a>
                </animate-scroll>
              </div>
          {% endif %}

          {% if rct_description %}
              <animate-scroll 
                class="richtext-prose text-caption flex flex-col space-y-2 [&amp;_*]:my-0 items-center text-center text-text opacity-0 block animate-eased-slide-up" 
                style="animation-delay: calc(2*100ms)">
                  <p><em>{{ rct_description|default('')|raw }}</em></p>
              </animate-scroll>
          {% endif %}

          {% if rct_cta_button is not empty %}
              {% include "components/button.twig" with {
								'label' : rct_cta_button.rct_cta_button_text|default(''),
								'link': rct_cta_button.rct_cta_button_url|default('#'),
								'aria_label' : rct_cta_button.rct_cta_button_arialabel|default(''),
								'add_class' : "",
								
							} %}
          {% endif %}
        </div>
      </div>
  </div>
</section>