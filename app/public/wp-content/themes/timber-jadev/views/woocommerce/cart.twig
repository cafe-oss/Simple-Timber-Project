{% extends 'base.twig' %}

{% block content %}
<article>
    <section>
        <div
            style="
                --section-spacing-sm: 0px;
                --section-spacing-md: 0px;
                --section-spacing-lg: 0px;
                --section-padding-sm: 3rem;
                --section-padding-md: 4rem;
                --section-padding-lg: 5rem;
                --columns-count-lg: 3;
                --scheme-background: 244 244 244;
                --scheme-text: 28 28 26;
            "
            class="bg-[rgb(244,244,244)] section-padding">
            <div class="wrapper">
                <h1 class="text-heading-xl mb-10 text-[rgb(28,28,26)]">Your Cart</h1>

                {# WooCommerce notices (cart updated, coupon errors, etc.) #}
                {% if wc_notices %}
                    <div class="mb-6 text-[rgb(28,28,26)]">{{ wc_notices|raw }}</div>
                {% endif %}

                {% if is_empty %}

                    {# ── Empty State ── #}
                    <div class="text-center py-20">
                        <p class="text-lg mb-8">Your cart is currently empty.</p>
                        {# <a href="{{ shop_page_url }}" #}
                        <a href="/product/tonal-2/"
                        class="inline-block px-8 py-3 bg-[rgb(28,28,26)] text-[rgb(244,244,244)] text-sm uppercase tracking-widest hover:opacity-90 transition-opacity"
                        style="color: rgb(244,244,244) !important;">
                            Continue Shopping
                        </a>
                    </div>

                {% else %}

                    <div class="flex flex-col lg:flex-row gap-10 items-start text-[rgb(28,28,26)]">

                        {# ══════════════════════════════════════════
                        LEFT — Cart Items
                        ══════════════════════════════════════════ #}
                        <div class="flex-1 min-w-0">

                            <form action="{{ cart_form_url }}" method="post">

                                {# Column headings #}
                                <div class="hidden md:grid grid-cols-[1fr_auto_auto] gap-4 pb-3 border-b border-gray-200 text-xs uppercase tracking-widest text-gray-500 font-medium">
                                    <span>Product</span>
                                    <span class="text-center w-24">Quantity</span>
                                    <span class="text-right w-24">Subtotal</span>
                                </div>

                                {# Items #}
                                <div class="divide-y divide-gray-200">
                                    {% for item in cart_items %}
                                    <div class="flex gap-4 py-6 items-start">

                                        {# Thumbnail #}
                                        <a href="{{ item.link }}" class="flex-shrink-0">
                                            <img src="{{ item.img_url }}"
                                                alt="{{ item.img_alt }}"
                                                width="96" height="96"
                                                class="w-24 h-24 object-cover">
                                        </a>

                                        {# Name + Remove #}
                                        <div class="flex-1 min-w-0">
                                            <a href="{{ item.link }}"
                                            class="font-medium text-sm leading-snug hover:underline block mb-1">
                                                {{ item.name }}
                                            </a>
                                            <a href="{{ item.remove_url }}"
                                            class="text-xs text-gray-400 hover:text-gray-700 underline underline-offset-2 transition-colors"
                                            aria-label="Remove {{ item.name }} from cart">
                                                Remove
                                            </a>
                                        </div>

                                        {# Quantity input #}
                                        <div class="flex-shrink-0 w-24 flex justify-center">
                                            <label for="qty-{{ item.key }}" class="sr-only">Quantity for {{ item.name }}</label>
                                            <input
                                                type="number"
                                                id="qty-{{ item.key }}"
                                                name="cart[{{ item.key }}][qty]"
                                                value="{{ item.quantity }}"
                                                min="0"
                                                step="1"
                                                class="w-16 py-1.5 px-2 text-sm text-center border border-gray-300 focus:outline-none focus:border-gray-500"
                                            >
                                        </div>

                                        {# Line price #}
                                        <div class="flex-shrink-0 w-24 text-right text-sm font-medium">
                                            {{ item.line_price|raw }}
                                        </div>

                                    </div>
                                    {% endfor %}
                                </div>

                                {# Form hidden fields + Update button #}
                                {{ cart_nonce_field|raw }}
                                <div class="mt-4 flex justify-end">
                                    <button type="submit"
                                            name="update_cart"
                                            value="Update Cart"
                                            class="text-xs uppercase tracking-widest underline underline-offset-4 hover:no-underline text-gray-500 transition-colors">
                                        Update Cart
                                    </button>
                                </div>

                            </form>
                        </div>

                        {# ══════════════════════════════════════════
                        RIGHT — Order Summary
                        ══════════════════════════════════════════ #}
                        <div class="w-full lg:w-80 xl:w-96 flex-shrink-0">
                            <div class="bg-gray-50 p-6">

                                <h2 class="text-sm uppercase tracking-widest font-semibold mb-6">Order Summary</h2>

                                {# ── Free-shipping progress ── #}
                                {% if free_shipping_threshold is defined %}
                                    <div class="mb-5 text-sm">
                                        {% if free_shipping_met %}
                                        <p class="text-green-600 font-medium">&#10003; You qualify for free shipping!</p>
                                        {% else %}
                                        <p class="text-gray-600">
                                            Add <strong>{{ free_shipping_remaining|raw }}</strong> more for free shipping.
                                        </p>
                                        <div class="mt-2 h-1 bg-gray-200 rounded-full overflow-hidden">
                                            <div class="h-full bg-[rgb(28,28,26)] transition-all duration-300"
                                                style="width: {{ free_shipping_pct }}%"></div>
                                        </div>
                                        {% endif %}
                                    </div>
                                {% endif %}

                                {# ── Subtotal ── #}
                                <div class="flex items-center justify-between py-3 border-b border-gray-200 text-sm">
                                    <span class="text-gray-600">Subtotal</span>
                                    <span id="cart-summary-subtotal" class="font-medium">{{ cart_subtotal|raw }}</span>
                                </div>

                                {# ── Applied coupons ── #}
                                <div id="cart-applied-coupons">
                                    {% for coupon in applied_coupons %}
                                    <div class="flex items-center justify-between py-2 text-sm text-green-700">
                                        <span>
                                            {{ coupon.label }}
                                            <button class="coupon-remove-btn text-xs underline ml-2 hover:no-underline"
                                                    data-code="{{ coupon.code }}">Remove</button>
                                        </span>
                                        <span>-{{ coupon.discount|raw }}</span>
                                    </div>
                                    {% endfor %}
                                </div>

                                {# ── Discount total ── #}
                                <div id="cart-discount-row"
                                     class="flex items-center justify-between py-3 border-b border-gray-200 text-sm text-green-700{% if not cart_discount %} hidden{% endif %}">
                                    <span>Discount</span>
                                    <span id="cart-discount-amount" class="font-medium">
                                        {% if cart_discount %}-{{ cart_discount|raw }}{% endif %}
                                    </span>
                                </div>

                                {# ── Shipping ── #}
                                {% if cart_shipping %}
                                <div class="flex items-center justify-between py-3 border-b border-gray-200 text-sm">
                                    <span class="text-gray-600">Shipping</span>
                                    <span class="font-medium">{{ cart_shipping|raw }}</span>
                                </div>
                                {% elseif needs_shipping %}
                                <div class="py-3 border-b border-gray-200 text-sm text-gray-500">
                                    Shipping &amp; taxes calculated at checkout
                                </div>
                                {% endif %}

                                {# ── Coupon form ── #}
                                <div class="py-4 border-b border-gray-200">
                                    <p class="text-xs uppercase tracking-widest font-medium mb-3">Coupon Code</p>
                                    <div class="flex gap-2">
                                        <input type="text"
                                               id="cart-coupon-input"
                                               placeholder="Enter code"
                                               autocomplete="off"
                                               class="flex-1 px-3 py-2 text-sm border border-gray-300 focus:outline-none focus:border-gray-500">
                                        <button id="cart-coupon-apply"
                                                class="px-4 py-2 text-xs uppercase tracking-widest bg-[rgb(28,28,26)] text-[rgb(244,244,244)] hover:opacity-90 transition-opacity whitespace-nowrap"
                                                style="color: rgb(244,244,244) !important;">
                                            Apply
                                        </button>
                                    </div>
                                    <div id="cart-coupon-message" class="mt-2 text-xs min-h-[1.25rem]"></div>
                                </div>

                                {# ── Total ── #}
                                <div class="flex items-center justify-between py-4 text-base font-semibold">
                                    <span>Total</span>
                                    <span id="cart-summary-total">{{ cart_total|raw }}</span>
                                </div>

                                {# Proceed to Checkout #}
                                <a href="{{ checkout_url }}"
                                class="block w-full text-center py-3 px-5 bg-[rgb(28,28,26)] text-[rgb(244,244,244)] text-sm uppercase tracking-widest hover:opacity-90 transition-opacity"
                                style="color: rgb(244,244,244) !important;">
                                    Proceed to Checkout
                                </a>

                                {# Continue shopping #}
                                <a href="/product/tonal-2/"
                                class="block w-full text-center pt-4 text-xs underline underline-offset-4 hover:no-underline text-gray-500">
                                    Continue Shopping
                                </a>

                            </div>
                        </div>

                    </div>
                {% endif %}
            </div>
        </div>
    </section>
</article>
{% endblock %}
