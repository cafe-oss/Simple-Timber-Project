{% extends "base.twig" %}

{% block content %}
	<article class="post-type-{{post.post_type}}" id="post-{{post.ID}}">

		{% include "components/hero-texts.twig" with {
			'title_row1': post.meta('title_row1'),
			'description_row1': post.meta('description_row1'),
			'rct_darkbg': "bg-background",
		}%}

		{% include "components/row-media.twig" with {
			'title_row2': post.meta('title_row2'),
			'description_row2': post.meta('description_row2'),
			'video': {
				'video_src': "//tonal.com/cdn/shop/videos/c/vp/d4a33af7f01c49a0b166205b756d2b27/d4a33af7f01c49a0b166205b756d2b27.HD-1080p-2.5Mbps-61032614.mp4?v=0",
				'video_poster': "//tonal.com/cdn/shop/files/preview_images/d4a33af7f01c49a0b166205b756d2b27.thumbnail.0000000000_3840x.jpg?v=1761623325",
			},
			'rct_darkbg': "bg-background",
		}%}

		{% include "components/row-content-text.twig" with {
			'rct_title': "Making progress, made easier",
			'rct_description': "Tap into your full power with smart features that intuitively adjust your training to challenge you as you get stronger.",
			'add_class': "!pb-0"
		}%}

		{% include "components/row-equipment-card.twig" with {
			equipments: [
					{
					'card_title': "Weight that adapts to you",
					'card_description': "Tonal learns your strength and sets the optimal resistance for every rep, increasing in as little as
				one-pound increments to keep you challenged as you get stronger.",
					'card_button_title': "Explore Smart Tech",
					'card_button_title_attribute': "Smart Technology",
					'card_button_url': "/pages/technology",
					'card_button_arialabel': "Explore smart technology",
					'card_image_src': "//tonal.com/cdn/shop/files/Home-S3-WeightThatAdaptsToYou.png?v=1745885064&amp;width=1000",
					'card_image_alt_attribute': "UI displaying showing 250lbs"
				},
				{
					'card_title': "Get more out of every rep",
					'card_description': "Science-backed workouts with real-time guidance help you train safely and maximize your effort.",
					'card_button_title': "See the Workouts",
					'card_button_title_attribute': "Workouts",
					'card_button_url': "/pages/workouts",
					'card_button_arialabel': "See the workout",
					'card_image_src': "//tonal.com/cdn/shop/files/Home-S3-GetMoreOutOfEveryRep-mobile.png?v=1745963295&amp;width=1000",
					'card_image_alt_attribute': "Woman doing RDLs"
				},
				{
					'card_title': "Gains without the guesswork",
					'card_description': "Tonal replaces standard gym equipment with smart tech that automatically tracks your progress and
				unlocks insights about your strength, so you can focus on hitting your goals.",
					'card_button_title': "Train With Tonal",
					'card_button_title_attribute': "Personalized Training",
					'card_button_url': "/pages/personalized-training",
					'card_button_arialabel': "Personalized training with Tonal",
					'card_image_src': "//tonal.com/cdn/shop/files/Home-S3-GainsWithoutTheGuesswork.png?v=1745887646&amp;width=1000",
					'card_image_alt_attribute': "Man looking past camera doing chest press"
				}
			],
			'add_class': "sm:!pb-[3rem] md:!pb-[4rem] lg:!pb-[5rem]",
		} 
		%}

		{% include "components/row-content-text.twig" with {
			'rct_title': "better form, safer training",
			'rct_description': "Tonal helps you dial in your form and guides you to train safely, lift confidently and get better results.",
			'rct_darkbg': "bg-background",
			'add_class': "!pb-0"
		}%}

		{% include "components/row-equipment-card.twig" with {
			equipments: [
					{
					'card_title': "Expert guidance",
					'card_description': "Tonal learns your strength and sets the optimal resistance for every rep, increasing in as little as one-pound increments to keep you challenged as you get stronger.",
					'card_image_src': "//tonal.com/cdn/shop/files/SmartTechnology-S4-ExpertGuidance.png?v=1747844102&width=1000",
					'card_image_alt_attribute': "Tonal expert looking at camera"
				},
				{
					'card_title': "Real-time coaching cues",
					'card_description': "Tonal analyzes your movements to give you real-time coaching cues like a personal trainer would to help you refine your form.",
					'card_image_src': "//tonal.com/cdn/shop/files/SmartTechnology-S4-RealTimeCoachingCues.png?v=1745963495&width=1000",
					'card_image_alt_attribute': "UI message showing coaching cues for Rep 2"
				},
				{
					'card_title': "Post-workout insights",
					'card_description': "With built in Smart View, Tonal serves up clips from your workouts with visual guidance on where you can improve, like a post-game film.",
					'card_image_src': "//tonal.com/cdn/shop/files/SmartTechnology-S4-PostWorkoutInsights.png?v=1745963495&width=1000",
					'card_image_alt_attribute': "UI showing post-workout insights over user video"
				}
			],
			'rct_darkbg': "bg-background",
			'add_class': "!pt-0 sm:!pb-[3rem] md:!pb-[4rem] lg:!pb-[5rem]",
		} 
		%}

		{% include "components/row-content-text.twig" with {
			'rct_title': "tonal membership unlocks everything you need to train smarter",
			'rct_description': "Each Tonal purchase requires a 12 month membership commitment of $59.95/month plus applicable sales tax.",
			'rct_button': {
				'rct_button_text': "Explore 300+ Movements",
				'rct_button_url': "https://tonal.com/blogs/movements",
			},
		}%}

		{% include "components/row-equipment-card.twig" with {
			'image_class': "w-[60px]! h-[90px]!",
			'rct_darkbg': "bg-background",
			equipments: [
					{
					'card_title': "book a demo today",
					'card_description': "Experience training with Tonal in person or virtually, guided by one of our experts.",
					'card_button_title': "BOOK ONLINE OR VIRTUAL",
					'card_button_title_attribute': "BOOK ONLINE OR VIRTUAL",
					'card_button_url': "https://tonal.com/pages/try-tonal",
					'card_image_src': "//tonal.com/cdn/shop/files/ICON_Laptop.svg?v=1769110328&width=1000",
				},
				{
					'card_title': "shop tonal now",
					'card_description': "Start your fitness journey today with Tonal 2.",
					'card_button_title': "SHOP NOW",
					'card_button_title_attribute': "SHOP NOW",
					'card_button_url': "https://tonal.com/products/tonal-2",
					'card_image_src': "//tonal.com/cdn/shop/files/ICON-Book-Tonal-Now.svg?v=1761607886&width=1000",
				},
				{
					'card_title': "Explore the Tonal app",
					'card_description': "See how you can set, track, and crush goals on the Tonal app. Plus, browse thousands of on-demand workouts to do at home with Tonal, or on the go without it.",
					'card_button_title': "DOWNLOAD THE APP",
					'card_button_title_attribute': "DOWNLOAD THE APP",
					'card_button_url': "https://tonal.com/pages/mobile",
					'card_image_src': "//tonal.com/cdn/shop/files/ICON-mobile.svg?v=1761607885&width=1000",
				}
			]
		} 
		%}

	</article>
{% endblock %}
