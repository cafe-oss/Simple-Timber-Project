					'testimonial_image_src': "//tonal.com/cdn/shop/files/ICON-Quote-Testimonials_75876310-9b9c-44ca-bdb2-26a5e701ecd5.svg?v=1761607885&width=1000",
					'testimonial_image_srcset_attribute': "//tonal.com/cdn/shop/files/ICON-Quote-Testimonials_75876310-9b9c-44ca-bdb2-26a5e701ecd5.svg?v=1761607885&width=352 352w, //tonal.com/cdn/shop/files/ICON-Quote-Testimonials_75876310-9b9c-44ca-bdb2-26a5e701ecd5.svg?v=1761607885&width=832 832w, //tonal.com/cdn/shop/files/ICON-Quote-Testimonials_75876310-9b9c-44ca-bdb2-26a5e701ecd5.svg?v=1761607885&width=1000 1000w",
